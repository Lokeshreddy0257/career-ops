<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ title|default("Lokesh Reddy — CV") }}</title>
<style>
  @page {
    size: Letter;
    margin: 0.6in 0.7in;
  }
  body {
    font-family: "Helvetica Neue", Arial, sans-serif;
    font-size: 10.5pt;
    line-height: 1.35;
    color: #111;
  }
  h1 {
    font-size: 18pt;
    margin: 0 0 2pt 0;
    letter-spacing: 0.3px;
  }
  h2 {
    font-size: 11.5pt;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 14pt 0 4pt 0;
    padding-bottom: 2pt;
    border-bottom: 0.6pt solid #222;
  }
  h3 {
    font-size: 10.5pt;
    margin: 8pt 0 1pt 0;
  }
  p { margin: 4pt 0; }
  ul { padding-left: 18pt; margin: 3pt 0 6pt 0; }
  li { margin: 1.5pt 0; }
  a  { color: #0a66c2; text-decoration: none; }
  .subtitle, .meta {
    font-size: 9.5pt;
    color: #555;
  }
  .container { max-width: 7.2in; }
</style>
</head>
<body>
  <div class="container">
    {{ body|safe }}
  </div>
</body>
</html>
