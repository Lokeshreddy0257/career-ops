# career-ops environment variables. Copy to `.env` and fill in.
# All variables are prefixed `CAREER_OPS_` and parsed by pydantic-settings.

# ── LLM provider ────────────────────────────────────────────────────
# Pick one. "anthropic" is the default; "openai" also works.
CAREER_OPS_LLM_PROVIDER=anthropic

# Anthropic
CAREER_OPS_ANTHROPIC_MODEL=claude-sonnet-4-5
CAREER_OPS_ANTHROPIC_API_KEY=

# OpenAI (optional, only needed if LLM_PROVIDER=openai)
CAREER_OPS_OPENAI_MODEL=gpt-4o
CAREER_OPS_OPENAI_API_KEY=

# ── Storage ─────────────────────────────────────────────────────────
# SQLite by default. Point at Postgres like:
#   postgresql+psycopg://user:pass@localhost:5432/career_ops
# and run alembic migrations.
# CAREER_OPS_DATABASE_URL=sqlite:///data/career.db

# ── Embeddings ──────────────────────────────────────────────────────
# Any sentence-transformers model works. Trade-off: speed vs quality.
#   all-MiniLM-L6-v2          — 384d, ~80MB, fast, good-enough quality (default)
#   BAAI/bge-small-en-v1.5    — 384d, ~130MB, higher quality
#   BAAI/bge-large-en-v1.5    — 1024d, ~1.3GB, best quality, slower
CAREER_OPS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
